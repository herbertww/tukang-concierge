# ─────────────────────────────────────────────
# Tukang MCP Server — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Server
PORT=8000
NODE_ENV=development

# SQLite database path (relative to project root)
DB_PATH=./tukang.db

# ── Mem0 ──────────────────────────────────────
# https://app.mem0.ai → API Keys
MEM0_API_KEY=your_mem0_api_key_here

# ── WhatsApp Business API ─────────────────────
# Meta for Developers → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
# Webhook verify token (any secret string you choose)
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here

# ── Stripe ────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
# Price ID for the $5 service fee product in Stripe
STRIPE_SERVICE_FEE_PRICE_ID=price_your_service_fee_price_id_here
# Public URL of this server (for Stripe success/cancel redirects)
PUBLIC_URL=https://your-server-domain.com

# ── Qwen Cloud (Alibaba Cloud) ─────────────────
# https://dashscope.aliyuncs.com → API Keys
QWEN_API_KEY=your_qwen_api_key_here
